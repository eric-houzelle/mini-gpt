{
  "training": {
    "num_epochs": 15,
    "batch_size": 16,
    "learning_rate": 2e-5,
    "warmup": 200,
    "gradient_accumulation_steps": 8,
    "max_grad_norm": 1.0
  },
  "model": {
    "embed_dim": 1536,
    "depth": 14,
    "heads": 24,
    "num_kv_heads": 6,
    "block_size": 512,
    "dropout": 0.05,
    "hidden_dim": 8192,
    "weight_sharing": "recurrent_depth",
    "use_rope": true,
    "use_gradient_checkpointing": true,
    "recurrent_depth": {
      "num_prelude_layers": 4,
      "num_coda_layers": 4,
      "num_recurrent_steps": 8,
      "use_lti_injection": true,
      "use_act_halting": true,
      "act_halt_threshold": 0.99,
      "depth_lora_rank": 32,
      "act_loss_weight": 0.01
    }
  },
  "data": {
    "max_texts_per_dataset": 200000,
    "train_split_ratio": 0.95
  },
  "datasets": [
    {
      "name": "kurakurai/luth-sft",
      "split": "luth_scholar",
      "format": "conversations",
      "conversations_key": "messages",
      "max_texts": 30000
    },
    {
      "name": "kurakurai/luth-sft",
      "split": "luth_tulu3_persona_instruct",
      "format": "conversations",
      "conversations_key": "messages",
      "max_texts": 20000
    },
    {
      "name": "kurakurai/luth-sft",
      "split": "luth_tulu3_persona_math",
      "format": "conversations",
      "conversations_key": "messages",
      "max_texts": 47000
    },
    {
      "name": "kurakurai/luth-sft",
      "split": "luth_smoltalk2",
      "format": "conversations",
      "conversations_key": "messages",
      "max_texts": 20000
    },
    {
      "name": "kurakurai/luth-sft",
      "split": "luth_openhermes",
      "format": "conversations",
      "conversations_key": "messages",
      "max_texts": 80000
    },
    {
      "name": "Houzeric/everyday-conversations",
      "format": "flat",
      "user_key": "user",
      "assistant_key": "assistant"
    },
    {
      "name": "angeluriot/french_instruct",
      "format": "conversations",
      "conversations_key": "conversation",
      "max_texts": 20000,
      "filter_column": "source",
      "exclude_values": [
        "Logic Inference OA (translated)",
        "Evol Instruct (translated)",
        "Human ChatGPT Comparison Corpus (translated)"
      ]
    },
    {
      "name": "Houzeric/physics-FR-qa-dataset",
      "format": "flat",
      "user_key": "question",
      "assistant_key": "answer",
      "max_texts": 5000
    }
  ]
}
