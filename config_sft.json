{
  "training": {
    "num_epochs": 3,
    "batch_size": 32,
    "learning_rate": 2e-5,
    "warmup": 200,
    "gradient_accumulation_steps": 4,
    "max_grad_norm": 1.0
  },
  "model": {
    "embed_dim": 768,
    "depth": 14,
    "heads": 12,
    "num_kv_heads": 4,
    "block_size": 256,
    "dropout": 0.05,
    "hidden_dim": 3072,
    "weight_sharing": "none",
    "use_rope": true,
    "use_gradient_checkpointing": false
  },
  "data": {
    "max_texts": 275000,
    "train_split_ratio": 0.95
  }
}
