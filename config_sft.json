{
  "training": {
    "num_epochs": 3,
    "batch_size": 32,
    "learning_rate": 2e-5,
    "warmup": 200,
    "gradient_accumulation_steps": 4,
    "max_grad_norm": 1.0
  },
  "model": {
    "embed_dim": 768,
    "depth": 14,
    "heads": 12,
    "num_kv_heads": 4,
    "block_size": 256,
    "dropout": 0.05,
    "hidden_dim": 3072,
    "weight_sharing": "none",
    "use_rope": true,
    "use_gradient_checkpointing": false
  },
  "data": {
    "max_texts_per_dataset": 200000,
    "train_split_ratio": 0.95
  },
  "datasets": [
    {
      "name": "Houzeric/everyday-conversations",
      "format": "flat",
      "user_key": "user",
      "assistant_key": "assistant"
    },
    {
      "name": "CATIE-AQ/facebook-community-alignment-dataset_french_conversation",
      "format": "conversations",
      "conversations_key": "conversation"
    },
    {
      "name": "angeluriot/french_instruct",
      "format": "conversations",
      "conversations_key": "conversation",
      "max_texts": 40000,
      "filter_column": "source",
      "exclude_values": [
        "Logic Inference OA (translated)",
        "Evol Instruct (translated)",
        "Human ChatGPT Comparison Corpus (translated)"
      ]
    },
    {
      "name": "jpacifico/French-Alpaca-dataset-Instruct-55K",
      "format": "alpaca",
      "max_texts": 20000
    },
    {
      "name": "Houzeric/french-prompts-and-questions",
      "format": "flat",
      "user_key": "prompt",
      "assistant_key": "answer",
      "max_texts": 15000,
      "filter_column": "type",
      "include_values": ["human_chatgpt"]
    },
    {
      "name": "Houzeric/physics-FR-qa-dataset",
      "format": "flat",
      "user_key": "question",
      "assistant_key": "answer",
      "max_texts": 5000
    }
  ]
}
