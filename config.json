{
  "training": {
    "num_epochs": 300,
    "batch_size": 128,
    "learning_rate": 1.2e-3,
    "warmup": 5000,
    "override_lr": null,
    "override_best_loss": null,
    "gradient_accumulation_steps": 1
  },
  "model": {
    "embed_dim": 768,
    "depth": 14,
    "heads": 12,
    "num_kv_heads": 4,
    "block_size": 256,
    "dropout": 0.05,
    "hidden_dim": 3072,
    "weight_sharing": "none",
    "use_rope": true,
    "use_gradient_checkpointing": false
  },
  "data": {
    "max_texts": 500000,
    "max_texts_per_dataset": 500000,
    "train_split_ratio": 0.90,
    "pretokenize": true,
    "progressive_block_sizes": [[0,128], [1000, 256], [2000, 256]]
  },
  "datasets": [
    {
      "name": "CATIE-AQ/wikipedia_fr_2022",
      "text_key": "text"
    },
    {
      "name": "HuggingFaceFW/fineweb-2",
      "subset": "fra_Latn",
      "text_key": "text",
      "max_texts": 13000000
    }
  ]
}